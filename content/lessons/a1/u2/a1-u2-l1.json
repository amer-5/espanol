  "grammar": [
    {
      "concept": "Nacionalnosti — rod i broj",
      "explanation_bs": "U španskom, nacionalnosti se mijenjaju prema rodu i broju, kao i pridjevi. Muškom rodu dodaješ -o (español), ženskom -a (española). Ako završava na suglasnik, ženski rod dodaje -a (francés → francesa). Množina: dodaješ -s (español → españoles, española → españolas). Sa SER, nacionalnost se piše MALIM slovom! (Soy bosnio, a NE: Soy Bosnio).",
      "table": {
        "headers": ["Zemlja", "Muški jd.", "Ženski jd.", "Muški mn.", "Ženski mn."],
        "rows": [
          ["España", "español", "española", "españoles", "españolas"],
          ["Bosnia", "bosnio", "bosnia", "bosnios", "bosnias"],
          ["Francia", "francés", "francesa", "franceses", "francesas"],
          ["Argentina", "argentino", "argentina", "argentinos", "argentinas"],
          ["América", "americano", "americana", "americanos", "americanas"]
        ]
      },
      "examples": [
        { "es": "Soy bosnio.", "bs": "Ja sam Bosanac. (muški)" },
        { "es": "Ella es española.", "bs": "Ona je Špankinja. (ženski)" },
        { "es": "Somos franceses.", "bs": "Mi smo Francuzi. (muški mn.)" }
      ],
      "tips": "Nacionalnosti u španskom se uvijek pišu MALIM slovom: soy español (ne Español)."
    },
    {
