        { "es": "¡Buenas noches! Hasta mañana.", "bs": "Laku noć! Do sutra." }
      ],
      "tips": "U Španiji se često kaže samo 'buenas' umjesto punog oblika — kratica za sve doba dana!"
    },
    {
      "concept": "Predstavljanje — me llamo vs soy",
      "explanation_bs": "Postoje dva načina da kažeš kako se zoveš: 'Me llamo...' (dosl. 'zovem se') i 'Soy...' (dosl. 'ja sam'). Oba su ispravna. 'Me llamo' je malo formalniji oblik koji češće čuješ u upoznavanju. 'Soy' je direktniji i kratki.",
      "examples": [
        { "es": "Me llamo Marko.", "bs": "Zovem se Marko." },
        { "es": "Soy Ana.", "bs": "Ja sam Ana." },
        { "es": "¿Cómo te llamas? Me llamo Carlos.", "bs": "Kako se zoveš? Zovem se Carlos." }
      ],
      "tips": "Za pitanje uvijek koristi '¿Cómo te llamas?' a odgovor možeš dati s 'me llamo' ili 'soy'."
    }
