  "grammar": [
    {
      "concept": "Osnovi pozdravi — kada koristiti koji",
      "explanation_bs": "Na španskom postoje pozdravi ovisno o dobu dana. 'Hola' je univerzalan i može se koristiti uvijek. 'Buenos días' je za jutro (do 12h), 'buenas tardes' za popodne i rano večer, 'buenas noches' za kasno veče i oproštaj noću. Zapamti: 'buenas noches' koristi se i kao pozdrav i kao oproštaj!",
      "examples": [
        { "es": "¡Hola! ¿Cómo estás?", "bs": "Zdravo! Kako si?" },
